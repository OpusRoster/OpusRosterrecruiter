# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── DEVELOPMENT MODE ────────────────────────────────────────────────────────
# When NEXT_PUBLIC_SUPABASE_URL is not set, the app runs in mock mode:
# - Auth is bypassed (mock session injected)
# - All data is served from src/lib/mock/
# - No real DB calls are made
# This is the default state for frontend-only testing.
